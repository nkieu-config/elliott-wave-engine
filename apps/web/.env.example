# Copy to .env.local and fill in. .env.local is gitignored.

# --- Required ---
# Base URL of the EWL FastAPI backend (apps/api).
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Optional: error/perf monitoring (Sentry) ---
# Leave blank to disable Sentry entirely (keeps the build free of @opentelemetry chunks).
# Browser SDK DSN (client-side capture + replay).
NEXT_PUBLIC_SENTRY_DSN=
# Server/edge SDK DSN.
SENTRY_DSN=
# Environment tag shown in Sentry (defaults to "development").
NEXT_PUBLIC_SENTRY_ENV=
SENTRY_ENV=
# Trace sample rate, 0..1 (defaults to 0.1). Public var feeds the browser SDK.
SENTRY_TRACES_SAMPLE_RATE=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=

# --- Optional: source-map upload (CI/prod builds only) ---
# Setting SENTRY_AUTH_TOKEN enables withSentryConfig (next.config.mjs).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Optional: metadata ---
# Absolute site origin for OG/Twitter image resolution (defaults to https://ewl.local).
NEXT_PUBLIC_SITE_URL=
